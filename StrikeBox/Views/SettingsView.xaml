<UserControl x:Class="StrikeBox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="设置"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel>

                <!-- ═══════ 解释器配置 ═══════ -->
                <TextBlock Text="解释器配置"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <!-- ═══ Python ═══ -->
                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Python"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <!-- 已配置的 Python 列表 -->
                        <ItemsControl ItemsSource="{Binding PythonInterpreters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="6"
                                            Padding="12,8"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Version}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />

                                            <ui:TextBox Grid.Column="1"
                                                        Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="解释器路径..."
                                                        Margin="8,0" />

                                            <ui:Button Grid.Column="2"
                                                       Content="浏览"
                                                       Appearance="Secondary"
                                                       FontSize="12"
                                                       Padding="8,4"
                                                       Command="{Binding DataContext.BrowsePythonEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />

                                            <ui:Button Grid.Column="3"
                                                       Content="✕"
                                                       Appearance="Danger"
                                                       FontSize="12"
                                                       Padding="6,4"
                                                       Margin="4,0,0,0"
                                                       Command="{Binding DataContext.RemovePythonInterpreterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 新增 Python -->
                        <Separator Margin="0,4,0,12"
                                   Background="{ui:ThemeResource CardStrokeColorDefaultBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:TextBox Text="{Binding NewPythonVersion, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="版本名"
                                        FontSize="13" />

                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding NewPythonPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="python.exe 路径..."
                                        Margin="8,0" />

                            <ui:Button Grid.Column="2"
                                       Content="浏览"
                                       Appearance="Secondary"
                                       FontSize="12"
                                       Padding="8,4"
                                       Command="{Binding BrowseNewPythonPathCommand}" />

                            <ui:Button Grid.Column="3"
                                       Content="添加"
                                       Appearance="Primary"
                                       FontSize="12"
                                       Padding="8,4"
                                       Margin="4,0,0,0"
                                       Command="{Binding AddPythonInterpreterCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ Java ═══ -->
                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Java"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <!-- 已配置的 Java 列表 -->
                        <ItemsControl ItemsSource="{Binding JavaInterpreters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="6"
                                            Padding="12,8"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Version}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />

                                            <ui:TextBox Grid.Column="1"
                                                        Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="解释器路径..."
                                                        Margin="8,0" />

                                            <ui:Button Grid.Column="2"
                                                       Content="浏览"
                                                       Appearance="Secondary"
                                                       FontSize="12"
                                                       Padding="8,4"
                                                       Command="{Binding DataContext.BrowseJavaEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />

                                            <ui:Button Grid.Column="3"
                                                       Content="✕"
                                                       Appearance="Danger"
                                                       FontSize="12"
                                                       Padding="6,4"
                                                       Margin="4,0,0,0"
                                                       Command="{Binding DataContext.RemoveJavaInterpreterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 新增 Java -->
                        <Separator Margin="0,4,0,12"
                                   Background="{ui:ThemeResource CardStrokeColorDefaultBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:TextBox Text="{Binding NewJavaVersion, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="版本名"
                                        FontSize="13" />

                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding NewJavaPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="java.exe 路径..."
                                        Margin="8,0" />

                            <ui:Button Grid.Column="2"
                                       Content="浏览"
                                       Appearance="Secondary"
                                       FontSize="12"
                                       Padding="8,4"
                                       Command="{Binding BrowseNewJavaPathCommand}" />

                            <ui:Button Grid.Column="3"
                                       Content="添加"
                                       Appearance="Primary"
                                       FontSize="12"
                                       Padding="8,4"
                                       Margin="4,0,0,0"
                                       Command="{Binding AddJavaInterpreterCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部保存 -->
        <Border Grid.Row="2"
                Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
            <ui:Button Content="保存设置"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Save16}"
                       Command="{Binding SaveCommand}"
                       HorizontalAlignment="Right" />
        </Border>
    </Grid>

</UserControl>
