<ui:FluentWindow x:Class="StrikeBox.Views.Dialogs.EditToolDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="{Binding DialogTitle}"
                 Width="600"
                 Height="640"
                 MinWidth="560"
                 MinHeight="580"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel>

                <!-- ═══════ 基本信息 ═══════ -->
                <TextBlock Text="工具信息"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,4" />
                <TextBlock Text="配置工具的基本信息"
                           FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,16" />

                <!-- 工具名称 -->
                <TextBlock Text="工具名称 *"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding ToolName, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="工具名称"
                            Margin="0,0,0,16" />

                <!-- 分类 + 工具类型（水平并排） -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="分类 *"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="工具类型 *"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding ToolTypes}"
                                  SelectedItem="{Binding SelectedType}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource ToolTypeToString}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Java 版本（仅 Java 类型显示） -->
                <StackPanel Visibility="{Binding IsJavaType, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,0,0,16">
                    <TextBlock Text="Java 版本 *"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding JavaVersions}"
                              SelectedItem="{Binding SelectedJavaVersion}" />
                </StackPanel>

                <!-- ── 分隔线 ── -->
                <Separator Margin="0,4,0,16"
                           Background="{ui:ThemeResource CardStrokeColorDefaultBrush}" />

                <!-- ═══════ 启动配置 ═══════ -->
                <TextBlock Text="启动配置"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,4" />
                <TextBlock Text="配置程序启动方式及运行参数"
                           FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,16" />

                <!-- 程序路径 -->
                <TextBlock Text="程序路径 *"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding ToolPath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="可执行文件路径" />
                    <ui:Button Grid.Column="1"
                               Content="浏览"
                               Margin="8,0,0,0"
                               Command="{Binding BrowsePathCommand}"
                               Visibility="{Binding IsNotWebType, Converter={StaticResource BoolToVisibility}}" />
                </Grid>

                <!-- 工作目录 -->
                <StackPanel Visibility="{Binding IsNotWebType, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,0,0,16">
                    <TextBlock Text="工作目录（可选）"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Text="{Binding WorkDir, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="留空默认使用程序所在目录" />
                        <ui:Button Grid.Column="1"
                                   Content="浏览"
                                   Margin="8,0,0,0"
                                   Command="{Binding BrowseWorkDirCommand}" />
                    </Grid>
                </StackPanel>

                <!-- 启动参数 -->
                <StackPanel Visibility="{Binding IsNotWebType, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,0,0,16">
                    <TextBlock Text="启动参数（可选）"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <ui:TextBox Text="{Binding Args, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="-h" />
                </StackPanel>

                <!-- ── 分隔线 ── -->
                <Separator Margin="0,4,0,16"
                           Background="{ui:ThemeResource CardStrokeColorDefaultBrush}" />

                <!-- ═══════ 提示 ═══════ -->
                <TextBlock Text="提示"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,2">
                    <Run Text="• " /><Run Text="*" Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}" /><Run Text=" 为必填项" />
                </TextBlock>
                <TextBlock FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,0">
                    <Run Text="• 路径支持 EXE、PY、JAR、URL" />
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- 按钮栏 -->
        <Border Grid.Row="1"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,16,0,0"
                Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="取消"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           Click="CancelButton_Click" />
                <ui:Button Content="保存工具"
                           Appearance="Primary"
                           Command="{Binding SubmitCommand}"
                           Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>

</ui:FluentWindow>
