<ui:FluentWindow x:Class="StrikeBox.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:StrikeBox.ViewModels"
                 xmlns:views="clr-namespace:StrikeBox.Views"
                 mc:Ignorable="d"
                 Title="StrikeBox"
                 Icon="Assets/StrikeBox.ico"
                 MinWidth="900"
                 MinHeight="550"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <!-- ViewModel -> View 映射 -->
        <DataTemplate DataType="{x:Type vm:ToolsViewModel}">
            <views:ToolsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoryManagerViewModel}">
            <views:CategoryManagerView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0"
                     Title="StrikeBox"
                     Background="Transparent" />

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 导航标题（呼吸动效） -->
                    <StackPanel Margin="16,20,16,16"
                                HorizontalAlignment="Center">
                        <StackPanel.Resources>
                            <Storyboard x:Key="LogoBreath" RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="LogoText"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.25" Duration="0:0:1.8" />
                                <DoubleAnimation Storyboard.TargetName="LogoText"
                                                 Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)"
                                                 From="0" To="20" Duration="0:0:1.8" />
                                <DoubleAnimation Storyboard.TargetName="LogoText"
                                                 Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                 From="0.2" To="1.0" Duration="0:0:1.8" />
                            </Storyboard>
                        </StackPanel.Resources>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="StackPanel.Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LogoBreath}" />
                            </EventTrigger>
                        </StackPanel.Triggers>
                        <TextBlock x:Name="LogoText"
                                   Text="StrikeBox"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#4D9FFF"
                                                  BlurRadius="0"
                                                  ShadowDepth="0"
                                                  Opacity="0.2" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- 导航菜单 -->
                    <ListBox x:Name="NavList"
                             Grid.Row="1"
                             Margin="8,8,8,16"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             ItemsSource="{Binding NavItems}"
                             SelectedItem="{Binding SelectedNavItem}"
                             DisplayMemberPath="Label">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{ui:ThemeResource SystemAccentColorPrimaryBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="False" />
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1"
                    Background="{ui:ThemeResource ApplicationBackgroundBrush}">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>
        </Grid>
    </Grid>

</ui:FluentWindow>
